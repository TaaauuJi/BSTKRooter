{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build BstkRooter",
            "type": "shell",
            "command": "${workspaceFolder}/build.bat",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Clean Build",
            "type": "shell",
            "command": "if (Test-Path build) { Remove-Item -Recurse -Force build }; Write-Host 'Clean done.'",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            }
        },
        {
            "label": "Run BstkRooter",
            "type": "shell",
            "command": "${workspaceFolder}/build/BstkRooter.exe",
            "dependsOn": "Build BstkRooter",
            "problemMatcher": [],
            "presentation": {
                "reveal": "silent"
            }
        }
    ]
}
